{
  "name": "crimson_duchess",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "infisical run --env=dev pnpm start",
    "start:dev-build": "pnpm run build && pnpm run start:dev",
    "start:prod": "infisical run --env=dev pnpm start",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "register:dev": "infisical run --env=dev node dist/registerCommands.js",
    "register:prod": "infisical run --env=prod node dist/registerCommands.js",
    "check:types": "tsc --noEmit",
    "check:dep": "node dist/test/debugDependancies.js",
    "preinstall": "npx only-allow pnpm"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@infisical/cli": "^0.43.87",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.0.8",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "npm": "please-use-pnpm",
    "pnpm": ">=9.0.0"
  }
}
